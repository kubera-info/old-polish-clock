        Include="%(wav.Outputs)" />
      <Link
        Include="%(wavDirsToMake.Identity)"
        Condition="'%(Extension)'=='.obj' or '%(Extension)'=='.res' or '%(Extension)'=='.rsc' or '%(Extension)'=='.lib'" />
      <Lib
        Include="%(wavDirsToMake.Identity)"
        Condition="'%(Extension)'=='.obj' or '%(Extension)'=='.res' or '%(Extension)'=='.rsc' or '%(Extension)'=='.lib'" />
      <ImpLib
        Include="%(wavDirsToMake.Identity)"
        Condition="'%(Extension)'=='.obj' or '%(Extension)'=='.res' or '%(Extension)'=='.rsc' or '%(Extension)'=='.lib'" />
    </ItemGroup>
    <MakeDir
      Directories="@(wavDirsToMake-&gt;'%(RootDir)%(Directory)')" />
  </Target>
  <Target
    Name="_Vbs2Vbe"
    BeforeTargets="$(Vbs2VbeBeforeTargets)"
    AfterTargets="$(Vbs2VbeAfterTargets)"
    Condition="'@(Vbs2Vbe)' != ''"
    DependsOnTargets="$(Vbs2VbeDependsOn);ComputeVbs2VbeOutput"
    Outputs="%(Vbs2Vbe.Outputs)"
    Inputs="%(Vbs2Vbe.Identity);%(Vbs2Vbe.AdditionalDependencies);$(MSBuildProjectFile)">
    <ItemGroup
      Condition="'@(SelectedFiles)' != ''">
      <Vbs2Vbe
        Remove="@(Vbs2Vbe)"
