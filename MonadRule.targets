    </ItemGroup>
    <ItemGroup>
      <Vbs2Vbe_tlog
        Include="%(Vbs2Vbe.Outputs)"
        Condition="'%(Vbs2Vbe.Outputs)' != '' and '%(Vbs2Vbe.ExcludedFromBuild)' != 'true'">
        <Source>@(Vbs2Vbe, '|')</Source>
      </Vbs2Vbe_tlog>
    </ItemGroup>
    <Message
      Importance="High"
      Text="%(Vbs2Vbe.ExecutionDescription)" />
    <WriteLinesToFile
      Condition="'@(Vbs2Vbe_tlog)' != '' and '%(Vbs2Vbe_tlog.ExcludedFromBuild)' != 'true'"
      File="$(IntDir)$(ProjectName).write.1.tlog"
      Lines="^%(Vbs2Vbe_tlog.Source);@(Vbs2Vbe_tlog-&gt;'%(Fullpath)')" />
    <Vbs2Vbe
      Condition="'@(Vbs2Vbe)' != '' and '%(Vbs2Vbe.ExcludedFromBuild)' != 'true'"
      CommandLineTemplate="%(Vbs2Vbe.CommandLineTemplate)"
      AdditionalOptions="%(Vbs2Vbe.AdditionalOptions)"
      Inputs="%(Vbs2Vbe.Identity)" />
  </Target>
  <PropertyGroup>
    <ComputeLinkInputsTargets>
            $(ComputeLinkInputsTargets);
            ComputeVbs2VbeOutput;
          </ComputeLinkInputsTargets>
    <ComputeLibInputsTargets>
            $(ComputeLibInputsTargets);
            ComputeVbs2VbeOutput;
          </ComputeLibInputsTargets>
  </PropertyGroup>
  <Target
    Name="ComputeVbs2VbeOutput"
    Condition="'@(Vbs2Vbe)' != ''">
    <ItemGroup>
      <Vbs2VbeDirsToMake
        Condition="'@(Vbs2Vbe)' != '' and '%(Vbs2Vbe.ExcludedFromBuild)' != 'true'"
        Include="%(Vbs2Vbe.Outputs)" />
      <Link
        Include="%(Vbs2VbeDirsToMake.Identity)"
        Condition="'%(Extension)'=='.obj' or '%(Extension)'=='.res' or '%(Extension)'=='.rsc' or '%(Extension)'=='.lib'" />
      <Lib
        Include="%(Vbs2VbeDirsToMake.Identity)"
        Condition="'%(Extension)'=='.obj' or '%(Extension)'=='.res' or '%(Extension)'=='.rsc' or '%(Extension)'=='.lib'" />
      <ImpLib
        Include="%(Vbs2VbeDirsToMake.Identity)"
        Condition="'%(Extension)'=='.obj' or '%(Extension)'=='.res' or '%(Extension)'=='.rsc' or '%(Extension)'=='.lib'" />
    </ItemGroup>
    <MakeDir
      Directories="@(Vbs2VbeDirsToMake-&gt;'%(RootDir)%(Directory)')" />
  </Target>
  <Target
    Name="_Mesh"
    BeforeTargets="$(MeshBeforeTargets)"
    AfterTargets="$(MeshAfterTargets)"
    Condition="'@(Mesh)' != ''"
    DependsOnTargets="$(MeshDependsOn);ComputeMeshOutput"
    Outputs="%(Mesh.Outputs)"
    Inputs="%(Mesh.Identity);%(Mesh.AdditionalDependencies);$(MSBuildProjectFile)">
    <ItemGroup
      Condition="'@(SelectedFiles)' != ''">
      <Mesh
        Remove="@(Mesh)"
        Condition="'%(Identity)' != '@(SelectedFiles)'" />
    </ItemGroup>
    <ItemGroup>
      <Mesh_tlog
        Include="%(Mesh.Outputs)"
        Condition="'%(Mesh.Outputs)' != '' and '%(Mesh.ExcludedFromBuild)' != 'true'">
        <Source>@(Mesh, '|')</Source>
      </Mesh_tlog>
    </ItemGroup>
    <Message
      Importance="High"
      Text="%(Mesh.ExecutionDescription)" />
    <WriteLinesToFile
      Condition="'@(Mesh_tlog)' != '' and '%(Mesh_tlog.ExcludedFromBuild)' != 'true'"
      File="$(IntDir)$(ProjectName).write.1.tlog"
      Lines="^%(Mesh_tlog.Source);@(Mesh_tlog-&gt;'%(Fullpath)')" />
    <Mesh
      Condition="'@(Mesh)' != '' and '%(Mesh.ExcludedFromBuild)' != 'true'"
      CommandLineTemplate="%(Mesh.CommandLineTemplate)"
      OnDemand="%(Mesh.OnDemand)"
      AdditionalOptions="%(Mesh.AdditionalOptions)"
      Inputs="%(Mesh.Identity)" />
  </Target>
  <PropertyGroup>
    <ComputeLinkInputsTargets>
            $(ComputeLinkInputsTargets);
            ComputeMeshOutput;
          </ComputeLinkInputsTargets>
    <ComputeLibInputsTargets>
            $(ComputeLibInputsTargets);
            ComputeMeshOutput;
          </ComputeLibInputsTargets>
  </PropertyGroup>
  <Target
    Name="ComputeMeshOutput"
    Condition="'@(Mesh)' != ''">
    <ItemGroup>
      <MeshDirsToMake
        Condition="'@(Mesh)' != '' and '%(Mesh.ExcludedFromBuild)' != 'true'"
        Include="%(Mesh.Outputs)" />
      <Link
        Include="%(MeshDirsToMake.Identity)"
        Condition="'%(Extension)'=='.obj' or '%(Extension)'=='.res' or '%(Extension)'=='.rsc' or '%(Extension)'=='.lib'" />
      <Lib
        Include="%(MeshDirsToMake.Identity)"
        Condition="'%(Extension)'=='.obj' or '%(Extension)'=='.res' or '%(Extension)'=='.rsc' or '%(Extension)'=='.lib'" />
      <ImpLib
        Include="%(MeshDirsToMake.Identity)"
        Condition="'%(Extension)'=='.obj' or '%(Extension)'=='.res' or '%(Extension)'=='.rsc' or '%(Extension)'=='.lib'" />
    </ItemGroup>
    <MakeDir
      Directories="@(MeshDirsToMake-&gt;'%(RootDir)%(Directory)')" />
  </Target>
</Project>