      AudioDest="%(wav.AudioDest)"
      AudioExt="%(wav.AudioExt)"
      AdditionalOptions="%(wav.AdditionalOptions)"
      Inputs="%(wav.Identity)" />
  </Target>
  <PropertyGroup>
    <ComputeLinkInputsTargets>
            $(ComputeLinkInputsTargets);
            ComputewavOutput;
          </ComputeLinkInputsTargets>
    <ComputeLibInputsTargets>
            $(ComputeLibInputsTargets);
            ComputewavOutput;
          </ComputeLibInputsTargets>
  </PropertyGroup>
  <Target
    Name="ComputewavOutput"
    Condition="'@(wav)' != ''">
    <ItemGroup>
      <wavDirsToMake
